{
    "name": "volume3",
        "globIgnorePaths": [
            "**/package.json",
            "**/tsconfig.json"
        ],
    "tree": {
        "$className": "Folder",
        "out": {
            "$path": "out"
        },
        "node_modules": {
            "$className": "Folder",
            "@rbxts": {
                "$path": "node_modules/@rbxts"
            }
        }
    }
}